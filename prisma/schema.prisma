datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Gender {
  male
  female
}

enum Role {
  USER
  DEVELOPER
}

enum ConversationType {
  DIRECT
  GROUP
}

enum DirectConversationStatus {
  PENDING
  ACCEPTED
}

enum ConversationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  USER
  GROUP
  MESSAGE
}

enum CallMediaType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ACTIVE
  ENDED
}

enum CallParticipantStatus {
  INVITED
  JOINED
  DECLINED
  MISSED
}

enum StoryMediaType {
  TEXT
  IMAGE
  VIDEO
}

model User {
  id                              String    @id @default(uuid())
  fullName                        String
  username                        String    @unique
  email                           String?   @unique
  password                        String
  passwordResetTokenHash          String?
  passwordResetTokenExpiresAt     DateTime?
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  emailVerifiedAt                 DateTime?
  gender                          Gender
  role                            Role      @default(USER)
  isPrimaryDeveloper              Boolean   @default(false)
  developerPermissions            Json?
  isArchived                      Boolean   @default(false)
  archivedAt                      DateTime?
  isBanned                        Boolean   @default(false)
  bannedAt                        DateTime?
  bannedReason                    String?
  isVerified                      Boolean   @default(false)
  verifiedAt                      DateTime?
  twoFactorEnabled                Boolean   @default(false)
  twoFactorSecret                 String?
  twoFactorPendingSecret          String?
  showOnlineStatus                Boolean   @default(true)
  showLastSeen                    Boolean   @default(true)
  showReadReceipts                Boolean   @default(true)
  showTypingStatus                Boolean   @default(true)
  profilePic                      String    @default("")
  bio                             String?   @default("")
  lastSeen                        DateTime?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  conversationsAsUserOne  Conversation[]           @relation("UserOne")
  conversationsAsUserTwo  Conversation[]           @relation("UserTwo")
  createdConversations    Conversation[]           @relation("GroupCreator")
  conversationMemberships ConversationMember[]
  sentMessages            Message[]                @relation("SentMessages")
  receivedMessages        Message[]                @relation("ReceivedMessages")
  createdReports          Report[]                 @relation("ReportsCreated")
  reviewedReports         Report[]                 @relation("ReportsReviewed")
  targetedReports         Report[]                 @relation("TargetUserReports")
  auditLogs               AuditLog[]               @relation("UserAuditLogs")
  createdCallSessions     CallSession[]            @relation("CreatedCallSessions")
  endedCallSessions       CallSession[]            @relation("EndedCallSessions")
  callParticipations      CallParticipant[]        @relation("CallParticipants")
  callInvitationsSent     CallParticipant[]        @relation("CallInvitationsSent")
  stories                 Story[]
  seenStories             StoryView[]              @relation("StoryViews")
  messageReactions        MessageReaction[]
  pinnedMessagesCreated   PinnedMessage[]          @relation("PinnedMessagesByUser")
  savedMessages           SavedMessage[]
  conversationPreferences ConversationPreference[]
  blockedUsers            UserBlock[]              @relation("BlocksInitiated")
  blockedByUsers          UserBlock[]              @relation("BlockedBy")
  sessions                UserSession[]
  loginChallenges         LoginChallenge[]
}

model Conversation {
  id                          String                   @id @default(uuid())
  type                        ConversationType         @default(DIRECT)
  userOneId                   String?
  userTwoId                   String?
  directStatus                DirectConversationStatus @default(ACCEPTED)
  directInitiatorId           String?
  directRespondedAt           DateTime?
  createdById                 String?
  title                       String?
  description                 String?                  @default("")
  profilePic                  String                   @default("")
  isPrivate                   Boolean                  @default(false)
  memberLimit                 Int?
  disappearingMessagesSeconds Int?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  userOne        User?                    @relation("UserOne", fields: [userOneId], references: [id])
  userTwo        User?                    @relation("UserTwo", fields: [userTwoId], references: [id])
  createdBy      User?                    @relation("GroupCreator", fields: [createdById], references: [id])
  members        ConversationMember[]
  messages       Message[]
  reports        Report[]                 @relation("TargetConversationReports")
  callSessions   CallSession[]
  pinnedMessages PinnedMessage[]
  preferences    ConversationPreference[]

  @@unique([userOneId, userTwoId, type])
  @@index([userOneId])
  @@index([userTwoId])
  @@index([directStatus])
  @@index([directInitiatorId])
  @@index([createdById])
  @@index([type])
}

model ConversationMember {
  conversationId String
  userId         String
  role           ConversationMemberRole @default(MEMBER)
  joinedAt       DateTime               @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id                     String    @id @default(uuid())
  conversationId         String
  senderId               String
  receiverId             String?
  message                String?
  audio                  String?
  audioDurationSeconds   Int?
  attachmentUrl          String?
  attachmentType         String?
  attachmentMimeType     String?
  attachmentFileName     String?
  attachmentFileSize     Int?
  attachmentResourceType String?
  repliedMessageId       String?
  isSeen                 Boolean   @default(false)
  deliveredAt            DateTime?
  editedAt               DateTime?
  expiresAt              DateTime?
  deletedFor             String[]  @default([])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation("SentMessages", fields: [senderId], references: [id])
  receiver       User?             @relation("ReceivedMessages", fields: [receiverId], references: [id])
  repliedMessage Message?          @relation("MessageReplies", fields: [repliedMessageId], references: [id], onDelete: SetNull)
  replies        Message[]         @relation("MessageReplies")
  reports        Report[]          @relation("TargetMessageReports")
  reactions      MessageReaction[]
  pinnedEntries  PinnedMessage[]
  savedEntries   SavedMessage[]

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([deliveredAt])
  @@index([expiresAt])
}

model Report {
  id                   String           @id @default(uuid())
  createdById          String?
  reviewedById         String?
  targetType           ReportTargetType
  status               ReportStatus     @default(OPEN)
  reason               String
  details              String?          @default("")
  resolutionNote       String?
  actionTaken          String?
  targetLabel          String?
  targetUserId         String?
  targetConversationId String?
  targetMessageId      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  reviewedAt           DateTime?

  createdBy          User?         @relation("ReportsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedBy         User?         @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  targetUser         User?         @relation("TargetUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetConversation Conversation? @relation("TargetConversationReports", fields: [targetConversationId], references: [id], onDelete: SetNull)
  targetMessage      Message?      @relation("TargetMessageReports", fields: [targetMessageId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([targetType])
  @@index([createdById])
  @@index([reviewedById])
  @@index([targetUserId])
  @@index([targetConversationId])
  @@index([targetMessageId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  summary     String
  details     Json?
  createdAt   DateTime @default(now())

  actor User? @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType])
  @@index([createdAt])
}

model CallSession {
  id             String        @id @default(uuid())
  conversationId String?
  createdById    String?
  endedById      String?
  mediaType      CallMediaType
  status         CallStatus    @default(RINGING)
  callMessageId  String?       @unique
  startedAt      DateTime      @default(now())
  connectedAt    DateTime?
  endedAt        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("CreatedCallSessions", fields: [createdById], references: [id], onDelete: SetNull)
  endedBy      User?             @relation("EndedCallSessions", fields: [endedById], references: [id], onDelete: SetNull)
  participants CallParticipant[]

  @@index([conversationId])
  @@index([createdById])
  @@index([endedById])
  @@index([status])
  @@index([startedAt])
}

model CallParticipant {
  id            String                @id @default(uuid())
  callSessionId String
  userId        String
  invitedById   String?
  status        CallParticipantStatus @default(INVITED)
  invitedAt     DateTime              @default(now())
  joinedAt      DateTime?
  leftAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User        @relation("CallParticipants", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?       @relation("CallInvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([callSessionId, userId])
  @@index([callSessionId])
  @@index([userId])
  @@index([status])
}

model Story {
  id            String         @id @default(uuid())
  userId        String
  text          String?        @default("")
  mediaUrl      String?
  mediaType     StoryMediaType @default(TEXT)
  mediaMimeType String?
  expiresAt     DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StoryView {
  storyId  String
  viewerId String
  seenAt   DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation("StoryViews", fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
  @@index([viewerId, seenAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt])
  @@index([userId, createdAt])
}

model PinnedMessage {
  id             String   @id @default(uuid())
  conversationId String
  messageId      String
  pinnedById     String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation("PinnedMessagesByUser", fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId, createdAt])
  @@index([pinnedById])
}

model SavedMessage {
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([userId, messageId])
  @@index([messageId])
  @@index([createdAt])
}

model ConversationPreference {
  conversationId String
  userId         String
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  mutedUntil     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, isArchived])
}

model UserBlock {
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker     User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlockedBy", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedUserId])
  @@index([blockedUserId])
}

model UserSession {
  id             String    @id @default(uuid())
  userId         String
  sessionTokenId String    @unique
  userAgent      String?
  ipAddress      String?
  lastSeenAt     DateTime  @default(now())
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, lastSeenAt])
}

model LoginChallenge {
  id             String   @id @default(uuid())
  userId         String
  challengeToken String   @unique
  codeHash       String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

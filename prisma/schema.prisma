datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Gender {
  male
  female
}

enum Role {
  USER
  DEVELOPER
}

enum ConversationType {
  DIRECT
  GROUP
}

enum DirectConversationStatus {
  PENDING
  ACCEPTED
}

enum ConversationMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum GroupJoinRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  USER
  GROUP
  MESSAGE
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VerificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BroadcastStatus {
  DRAFT
  SENT
  FAILED
}

enum BroadcastType {
  IN_APP
  EMAIL
  BOTH
}

enum BroadcastAudienceType {
  ALL_USERS
  ACTIVE_USERS
  VERIFIED_USERS
  UNVERIFIED_USERS
  DEVELOPERS
}

enum SecurityEventType {
  FAILED_LOGIN
  LOGIN_SUCCESS
  ACCOUNT_LOCKED
  SUSPICIOUS_IP
  SESSION_REVOKED
  PASSWORD_RESET
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  EMAIL_VERIFIED
  VERIFIED_BADGE_GRANTED
  VERIFIED_BADGE_REVOKED
}

enum SecurityRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModerationRuleScope {
  MESSAGE
  USERNAME
  PROFILE
  REPORT
}

enum CallMediaType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ACTIVE
  ENDED
}

enum CallParticipantStatus {
  INVITED
  JOINED
  DECLINED
  MISSED
}

enum StoryMediaType {
  TEXT
  IMAGE
  VIDEO
}

model User {
  id                              String    @id @default(uuid())
  fullName                        String
  username                        String    @unique
  email                           String?   @unique
  password                        String
  passwordResetTokenHash          String?
  passwordResetTokenExpiresAt     DateTime?
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  emailVerifiedAt                 DateTime?
  gender                          Gender
  role                            Role      @default(USER)
  isPrimaryDeveloper              Boolean   @default(false)
  developerPermissions            Json?
  isArchived                      Boolean   @default(false)
  archivedAt                      DateTime?
  isBanned                        Boolean   @default(false)
  bannedAt                        DateTime?
  bannedReason                    String?
  isVerified                      Boolean   @default(false)
  verifiedAt                      DateTime?
  twoFactorEnabled                Boolean   @default(false)
  twoFactorSecret                 String?
  twoFactorPendingSecret          String?
  failedLoginAttempts             Int       @default(0)
  lockedUntil                     DateTime?
  showOnlineStatus                Boolean   @default(true)
  showLastSeen                    Boolean   @default(true)
  showReadReceipts                Boolean   @default(true)
  showTypingStatus                Boolean   @default(true)
  profilePic                      String    @default("")
  bio                             String?   @default("")
  lastSeen                        DateTime?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  conversationsAsUserOne       Conversation[]           @relation("UserOne")
  conversationsAsUserTwo       Conversation[]           @relation("UserTwo")
  createdConversations         Conversation[]           @relation("GroupCreator")
  conversationMemberships      ConversationMember[]
  sentMessages                 Message[]                @relation("SentMessages")
  receivedMessages             Message[]                @relation("ReceivedMessages")
  createdReports               Report[]                 @relation("ReportsCreated")
  reviewedReports              Report[]                 @relation("ReportsReviewed")
  assignedReports              Report[]                 @relation("ReportsAssigned")
  targetedReports              Report[]                 @relation("TargetUserReports")
  reportStatusEvents           ReportStatusEvent[]      @relation("ReportStatusEventsActor")
  auditLogs                    AuditLog[]               @relation("UserAuditLogs")
  createdSupportTickets        SupportTicket[]          @relation("SupportTicketsCreated")
  assignedSupportTickets       SupportTicket[]          @relation("SupportTicketsAssigned")
  supportTicketMessages        SupportTicketMessage[]   @relation("SupportTicketMessagesAuthor")
  verificationRequests         VerificationRequest[]    @relation("VerificationRequestsTarget")
  createdVerificationRequests  VerificationRequest[]    @relation("VerificationRequestsCreatedBy")
  reviewedVerificationRequests VerificationRequest[]    @relation("VerificationRequestsReviewedBy")
  securityEvents               SecurityEvent[]
  createdModerationRules       ContentModerationRule[]  @relation("ModerationRulesCreated")
  createdBroadcastCampaigns    BroadcastCampaign[]      @relation("BroadcastCampaignsCreated")
  featureFlagsCreated          FeatureFlag[]            @relation("FeatureFlagsCreated")
  featureFlagsUpdated          FeatureFlag[]            @relation("FeatureFlagsUpdated")
  createdCallSessions          CallSession[]            @relation("CreatedCallSessions")
  endedCallSessions            CallSession[]            @relation("EndedCallSessions")
  callParticipations           CallParticipant[]        @relation("CallParticipants")
  callInvitationsSent          CallParticipant[]        @relation("CallInvitationsSent")
  stories                      Story[]
  seenStories                  StoryView[]              @relation("StoryViews")
  messageReactions             MessageReaction[]
  pinnedMessagesCreated        PinnedMessage[]          @relation("PinnedMessagesByUser")
  savedMessages                SavedMessage[]
  conversationPreferences      ConversationPreference[]
  blockedUsers                 UserBlock[]              @relation("BlocksInitiated")
  blockedByUsers               UserBlock[]              @relation("BlockedBy")
  sessions                     UserSession[]
  loginChallenges              LoginChallenge[]
  createdGroupInviteLinks      GroupInviteLink[]        @relation("GroupInviteLinksCreated")
  groupJoinRequests            GroupJoinRequest[]       @relation("GroupJoinRequestUser")
  respondedJoinRequests        GroupJoinRequest[]       @relation("GroupJoinRequestResponder")
  createdGroupPolls            GroupPoll[]              @relation("GroupPollsCreated")
  groupPollVotes               GroupPollVote[]
  createdGroupEvents           GroupEvent[]             @relation("GroupEventsCreated")
  createdAnnouncements         GroupAnnouncement[]      @relation("GroupAnnouncementsCreated")
}

model Conversation {
  id                          String                   @id @default(uuid())
  type                        ConversationType         @default(DIRECT)
  userOneId                   String?
  userTwoId                   String?
  directStatus                DirectConversationStatus @default(ACCEPTED)
  directInitiatorId           String?
  directRespondedAt           DateTime?
  createdById                 String?
  title                       String?
  description                 String?                  @default("")
  profilePic                  String                   @default("")
  isPrivate                   Boolean                  @default(false)
  memberLimit                 Int?
  disappearingMessagesSeconds Int?
  slowModeSeconds             Int?
  pinnedRules                 Json?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  userOne        User?                    @relation("UserOne", fields: [userOneId], references: [id])
  userTwo        User?                    @relation("UserTwo", fields: [userTwoId], references: [id])
  createdBy      User?                    @relation("GroupCreator", fields: [createdById], references: [id])
  members        ConversationMember[]
  messages       Message[]
  reports        Report[]                 @relation("TargetConversationReports")
  callSessions   CallSession[]
  pinnedMessages PinnedMessage[]
  preferences    ConversationPreference[]
  inviteLinks    GroupInviteLink[]
  joinRequests   GroupJoinRequest[]
  polls          GroupPoll[]
  events         GroupEvent[]
  announcements  GroupAnnouncement[]

  @@unique([userOneId, userTwoId, type])
  @@index([userOneId])
  @@index([userTwoId])
  @@index([directStatus])
  @@index([directInitiatorId])
  @@index([createdById])
  @@index([type])
}

model ConversationMember {
  conversationId String
  userId         String
  role           ConversationMemberRole @default(MEMBER)
  joinedAt       DateTime               @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id                     String    @id @default(uuid())
  conversationId         String
  senderId               String
  receiverId             String?
  message                String?
  audio                  String?
  audioDurationSeconds   Int?
  attachmentUrl          String?
  attachmentType         String?
  attachmentMimeType     String?
  attachmentFileName     String?
  attachmentFileSize     Int?
  attachmentResourceType String?
  repliedMessageId       String?
  isSeen                 Boolean   @default(false)
  deliveredAt            DateTime?
  editedAt               DateTime?
  expiresAt              DateTime?
  deletedFor             String[]  @default([])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation("SentMessages", fields: [senderId], references: [id])
  receiver       User?             @relation("ReceivedMessages", fields: [receiverId], references: [id])
  repliedMessage Message?          @relation("MessageReplies", fields: [repliedMessageId], references: [id], onDelete: SetNull)
  replies        Message[]         @relation("MessageReplies")
  reports        Report[]          @relation("TargetMessageReports")
  reactions      MessageReaction[]
  pinnedEntries  PinnedMessage[]
  savedEntries   SavedMessage[]

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([deliveredAt])
  @@index([expiresAt])
}

model Report {
  id                   String           @id @default(uuid())
  createdById          String?
  reviewedById         String?
  assignedToId         String?
  targetType           ReportTargetType
  status               ReportStatus     @default(OPEN)
  priority             ReportPriority   @default(MEDIUM)
  reason               String
  details              String?          @default("")
  resolutionNote       String?
  actionTaken          String?
  targetLabel          String?
  targetUserId         String?
  targetConversationId String?
  targetMessageId      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  reviewedAt           DateTime?

  createdBy          User?               @relation("ReportsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedBy         User?               @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  assignedTo         User?               @relation("ReportsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  targetUser         User?               @relation("TargetUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetConversation Conversation?       @relation("TargetConversationReports", fields: [targetConversationId], references: [id], onDelete: SetNull)
  targetMessage      Message?            @relation("TargetMessageReports", fields: [targetMessageId], references: [id], onDelete: SetNull)
  events             ReportStatusEvent[]

  @@index([status])
  @@index([priority])
  @@index([targetType])
  @@index([createdById])
  @@index([reviewedById])
  @@index([assignedToId])
  @@index([targetUserId])
  @@index([targetConversationId])
  @@index([targetMessageId])
  @@index([createdAt])
}

model ReportStatusEvent {
  id          String          @id @default(uuid())
  reportId    String
  actorId     String?
  status      ReportStatus
  priority    ReportPriority?
  note        String?
  actionTaken String?
  createdAt   DateTime        @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actor  User?  @relation("ReportStatusEventsActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt])
  @@index([actorId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  summary     String
  details     Json?
  createdAt   DateTime @default(now())

  actor User? @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType])
  @@index([createdAt])
}

model SupportTicket {
  id             String                @id @default(uuid())
  createdById    String
  assignedToId   String?
  subject        String
  category       String                @default("GENERAL")
  status         SupportTicketStatus   @default(OPEN)
  priority       SupportTicketPriority @default(MEDIUM)
  details        String
  resolutionNote String?
  tags           String[]              @default([])
  closedAt       DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  createdBy  User                   @relation("SupportTicketsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  assignedTo User?                  @relation("SupportTicketsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   SupportTicketMessage[]

  @@index([createdById, createdAt])
  @@index([assignedToId, status])
  @@index([status, priority, createdAt])
}

model SupportTicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation("SupportTicketMessagesAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorId, createdAt])
}

model VerificationRequest {
  id            String                    @id @default(uuid())
  userId        String
  requestedById String
  reviewedById  String?
  status        VerificationRequestStatus @default(PENDING)
  requestNote   String?
  reviewNote    String?
  proofLinks    String[]                  @default([])
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  reviewedAt    DateTime?

  user        User  @relation("VerificationRequestsTarget", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("VerificationRequestsCreatedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User? @relation("VerificationRequestsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([reviewedById, status])
}

model SecurityEvent {
  id        String            @id @default(uuid())
  userId    String?
  eventType SecurityEventType
  riskLevel SecurityRiskLevel @default(LOW)
  ipAddress String?
  userAgent String?
  summary   String
  details   Json?
  createdAt DateTime          @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([riskLevel, createdAt])
}

model ContentModerationRule {
  id          String              @id @default(uuid())
  label       String
  pattern     String
  isRegex     Boolean             @default(false)
  scope       ModerationRuleScope @default(MESSAGE)
  severity    ReportPriority      @default(MEDIUM)
  actionHint  String?
  isActive    Boolean             @default(true)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy User? @relation("ModerationRulesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([scope, isActive, createdAt])
  @@index([createdById])
}

model BroadcastCampaign {
  id                 String                @id @default(uuid())
  createdById        String
  title              String
  subject            String?
  content            String
  type               BroadcastType         @default(IN_APP)
  audienceType       BroadcastAudienceType @default(ALL_USERS)
  status             BroadcastStatus       @default(DRAFT)
  filterJson         Json?
  audienceCount      Int                   @default(0)
  deliveryCount      Int                   @default(0)
  emailDeliveryCount Int                   @default(0)
  failureReason      String?
  sentAt             DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  createdBy User @relation("BroadcastCampaignsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model FeatureFlag {
  id               String   @id @default(uuid())
  key              String   @unique
  name             String
  description      String?  @default("")
  isEnabled        Boolean  @default(false)
  rolloutPercent   Int      @default(0)
  targetRoles      String[] @default([])
  allowListUserIds String[] @default([])
  createdById      String?
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy User? @relation("FeatureFlagsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("FeatureFlagsUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isEnabled, updatedAt])
  @@index([createdById])
  @@index([updatedById])
}

model CallSession {
  id             String        @id @default(uuid())
  conversationId String?
  createdById    String?
  endedById      String?
  mediaType      CallMediaType
  status         CallStatus    @default(RINGING)
  callMessageId  String?       @unique
  startedAt      DateTime      @default(now())
  connectedAt    DateTime?
  endedAt        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("CreatedCallSessions", fields: [createdById], references: [id], onDelete: SetNull)
  endedBy      User?             @relation("EndedCallSessions", fields: [endedById], references: [id], onDelete: SetNull)
  participants CallParticipant[]

  @@index([conversationId])
  @@index([createdById])
  @@index([endedById])
  @@index([status])
  @@index([startedAt])
}

model CallParticipant {
  id            String                @id @default(uuid())
  callSessionId String
  userId        String
  invitedById   String?
  status        CallParticipantStatus @default(INVITED)
  invitedAt     DateTime              @default(now())
  joinedAt      DateTime?
  leftAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User        @relation("CallParticipants", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?       @relation("CallInvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([callSessionId, userId])
  @@index([callSessionId])
  @@index([userId])
  @@index([status])
}

model Story {
  id            String         @id @default(uuid())
  userId        String
  text          String?        @default("")
  mediaUrl      String?
  mediaType     StoryMediaType @default(TEXT)
  mediaMimeType String?
  expiresAt     DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StoryView {
  storyId  String
  viewerId String
  seenAt   DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation("StoryViews", fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
  @@index([viewerId, seenAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt])
  @@index([userId, createdAt])
}

model PinnedMessage {
  id             String   @id @default(uuid())
  conversationId String
  messageId      String
  pinnedById     String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation("PinnedMessagesByUser", fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId, createdAt])
  @@index([pinnedById])
}

model SavedMessage {
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([userId, messageId])
  @@index([messageId])
  @@index([createdAt])
}

model ConversationPreference {
  conversationId String
  userId         String
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  mutedUntil     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, isArchived])
}

model GroupInviteLink {
  id             String    @id @default(uuid())
  conversationId String
  code           String    @unique
  createdById    String
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy    User               @relation("GroupInviteLinksCreated", fields: [createdById], references: [id], onDelete: Cascade)
  joinRequests GroupJoinRequest[]

  @@index([conversationId, revokedAt, createdAt])
  @@index([createdById])
}

model GroupJoinRequest {
  id             String                 @id @default(uuid())
  conversationId String
  requesterId    String
  inviteLinkId   String?
  status         GroupJoinRequestStatus @default(PENDING)
  message        String?                @default("")
  respondedById  String?
  respondedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  requester    User             @relation("GroupJoinRequestUser", fields: [requesterId], references: [id], onDelete: Cascade)
  inviteLink   GroupInviteLink? @relation(fields: [inviteLinkId], references: [id], onDelete: SetNull)
  respondedBy  User?            @relation("GroupJoinRequestResponder", fields: [respondedById], references: [id], onDelete: SetNull)

  @@index([conversationId, status, createdAt])
  @@index([requesterId, status, createdAt])
}

model GroupPoll {
  id             String    @id @default(uuid())
  conversationId String
  question       String
  allowsMultiple Boolean   @default(false)
  closesAt       DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation  Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy     User              @relation("GroupPollsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  options       GroupPollOption[]
  GroupPollVote GroupPollVote[]

  @@index([conversationId, createdAt])
  @@index([createdById])
}

model GroupPollOption {
  id       String @id @default(uuid())
  pollId   String
  label    String
  position Int

  poll  GroupPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes GroupPollVote[]

  @@index([pollId, position])
}

model GroupPollVote {
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   GroupPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option GroupPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([optionId, userId])
  @@index([pollId, userId])
}

model GroupEvent {
  id             String    @id @default(uuid())
  conversationId String
  title          String
  description    String?   @default("")
  startsAt       DateTime
  endsAt         DateTime?
  location       String?   @default("")
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("GroupEventsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([conversationId, startsAt])
  @@index([createdById])
}

model GroupAnnouncement {
  id             String   @id @default(uuid())
  conversationId String
  content        String
  createdById    String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("GroupAnnouncementsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([createdById])
}

model UserBlock {
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker     User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlockedBy", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedUserId])
  @@index([blockedUserId])
}

model UserSession {
  id             String    @id @default(uuid())
  userId         String
  sessionTokenId String    @unique
  userAgent      String?
  ipAddress      String?
  lastSeenAt     DateTime  @default(now())
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, lastSeenAt])
}

model LoginChallenge {
  id             String   @id @default(uuid())
  userId         String
  challengeToken String   @unique
  codeHash       String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
